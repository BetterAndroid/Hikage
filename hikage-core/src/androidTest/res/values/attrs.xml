<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="AttrProbeView">
        <attr name="hikageProbeMode" format="enum">
            <enum name="primary" value="1" />
            <enum name="secondary" value="2" />
            <enum name="negative" value="-1" />
        </attr>
        <attr name="hikageProbeFlags" format="flags">
            <flag name="none" value="0" />
            <flag name="alpha" value="1" />
            <flag name="beta" value="2" />
            <flag name="gamma" value="4" />
        </attr>
        <attr name="hikageProbeInt" format="integer" />
        <attr name="hikageProbeDimension" format="dimension" />
        <attr name="hikageProbeColor" format="color" />
        <attr name="hikageProbeBoolean" format="boolean" />
        <attr name="hikageProbeString" format="string" />
        <attr name="hikageProbeReference" format="reference" />
        <attr name="hikageProbeFraction" format="fraction" />
        <attr name="hikageProbeFloat" format="float" />
    </declare-styleable>
</resources>